---
import BaseLayout from "../layouts/BaseLayout.astro";
import profile from "../data/profile.json";
---

<BaseLayout
  title="Pushkar Vashisht - Choose the Dossier or Fun XP"
  description="Choose between Pushkar Vashisht's premium formal dossier and an interactive Windows XP-inspired portfolio."
>
  <main class="route-shell selector-shell">
    <section class="selector-hero">
      <div>
        <p class="eyebrow">Pick your route</p>
        <h1>Pushkar Vashisht</h1>
      </div>
      <p class="selector-copy">
        Choose the direct dossier or the playful XP portfolio. Same work, different reading mode.
      </p>
    </section>

    <section class="mode-grid" aria-label="Portfolio modes">
      <a class="mode-card mode-card-dark" href="/formal">
        <span class="mode-kicker">Formal Dossier</span>
        <h2>Proof, cases and contact in one clean pass.</h2>
        <p>{profile.stats[0].value} creators · {profile.stats[1].value} activations · {profile.stats[2].value} startups</p>
        <span class="mode-action">Open dossier</span>
      </a>

      <a class="mode-card mode-card-light" href="/xp">
        <span class="mode-kicker">Fun XP OS</span>
        <h2>A browsable desktop version of the same portfolio.</h2>
        <p>Cases, reels, contact tools and a few playful interactions.</p>
        <span class="mode-action">Boot XP</span>
      </a>
    </section>

    <section class="selector-contact" aria-label="Direct contact">
      <a href={`mailto:${profile.email}`}>{profile.email}</a>
      <a href={`tel:${profile.phone}`}>{profile.phone}</a>
    </section>
  </main>
</BaseLayout>
