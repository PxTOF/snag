---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FormalSpaceScene from "../../components/formal/FormalSpaceScene.jsx";
import profile from "../../data/profile.json";
import cases from "../../data/cases.json";
import reels from "../../data/reels.json";

const featuredCases = cases.slice(0, 4);
const mailHref = `mailto:${profile.email}?subject=Brand%20%2F%20growth%20role%20for%20Pushkar`;
const pitchCopy = `${profile.name}: ${profile.pitch}`;
---

<BaseLayout
  title={`${profile.name} - High-Tech Formal Dossier`}
  description={`${profile.headline} ${profile.subheadline}`}
  canonical="/formal"
  image={profile.profileImage}
  pageClass="space-page"
>
  <main class="space-dossier" data-space-dossier>
    <FormalSpaceScene client:load />

    <div class="space-preloader" aria-hidden="true">
      <div>
        <span>PV / dossier boot</span>
        <strong>calibrating proof signal</strong>
        <i></i>
      </div>
    </div>

    <header class="space-nav" data-space-reveal>
      <a class="space-brand" href="/" aria-label="Back to mode selector">
        <span class="space-brand-mark">PV</span>
        <span>
          <b>{profile.name}</b>
          <small>Proof-led creative operator</small>
        </span>
      </a>
      <nav aria-label="Formal dossier navigation">
        <a href="#cases">Cases</a>
        <a href="#reels">Reels</a>
        <a href="/xp">Fun XP</a>
        <a class="space-nav-cta" href={profile.cvUrl} download>Download CV</a>
      </nav>
    </header>

    <section class="space-hero" aria-labelledby="formal-title">
      <div class="space-hero-copy" data-space-reveal>
        <p class="space-kicker">Formal dossier / brand growth orbit</p>
        <h1 id="formal-title">{profile.headline}</h1>
        <p class="space-hero-lede">{profile.subheadline}</p>
        <div class="space-hero-actions" aria-label="Primary actions">
          <a class="space-primary" href={mailHref}>Start the conversation</a>
          <a href="#cases">See proof</a>
          <button type="button" data-copy-pitch={pitchCopy}>Copy pitch</button>
        </div>
      </div>

      <aside class="space-id" aria-label="Candidate identity" data-space-reveal>
        <div class="space-id-frame">
          <img src={profile.profileImage} alt="Pushkar Vashisht" />
          <div class="space-id-scan"></div>
        </div>
        <div class="space-id-meta">
          <span>Candidate signal</span>
          <b>{profile.name}</b>
          <p>{profile.pitch}</p>
        </div>
      </aside>
    </section>

    <section class="space-proof-grid" aria-label="Proof stats">
      {profile.stats.map((stat, index) => (
        <article class="space-stat" data-space-reveal style={`--delay: ${index * 80}ms`}>
          <span>{String(index + 1).padStart(2, "0")}</span>
          <strong>{stat.value}</strong>
          <p>{stat.label}</p>
        </article>
      ))}
    </section>

    <section class="space-orbit-story" aria-labelledby="useful-title">
      <div class="space-sticky-copy" data-space-reveal>
        <p class="space-kicker">What he is useful for</p>
        <h2 id="useful-title">Not a deck-maker. Not a caption machine. A taste-led operator who can make growth look alive.</h2>
      </div>
      <div class="space-use-list">
        {profile.fit.map((fit, index) => (
          <article class="space-use-card" data-space-reveal style={`--delay: ${index * 90}ms`}>
            <span>0{index + 1}</span>
            <p>{fit}</p>
          </article>
        ))}
        <article class="space-use-card space-use-card-wide" data-space-reveal>
          <span>field note</span>
          <p>Best used when the brief is still messy, the audience has taste, and the work has to become visible fast without turning fake.</p>
        </article>
      </div>
    </section>

    <section id="cases" class="space-section case-section" aria-labelledby="cases-title">
      <div class="space-section-head" data-space-reveal>
        <p class="space-kicker">Proof that has a point of view.</p>
        <h2 id="cases-title">Case files built like mission logs.</h2>
        <p>Each one carries the useful recruiter question: what was unclear, what moved, and why the proof matters.</p>
      </div>

      <div class="space-case-scroll">
        {featuredCases.map((item, index) => (
          <article class="space-case-card" data-space-reveal style={`--delay: ${index * 80}ms`}>
            <a href={`/formal/cases/${item.id}`} aria-label={`Open ${item.title} case study`}>
              <span class="space-case-index">{String(index + 1).padStart(2, "0")}</span>
              <div>
                <p>{item.year} / {item.role}</p>
                <h3>{item.title}</h3>
                <strong>{item.metric}</strong>
              </div>
              <p>{item.summary}</p>
              <div class="space-tags">
                {item.tags.map((tag) => <span>{tag}</span>)}
              </div>
            </a>
          </article>
        ))}
      </div>
    </section>

    <section class="space-shortlist" aria-labelledby="shortlist-title">
      <div data-space-reveal>
        <p class="space-kicker">Signal stack</p>
        <h2 id="shortlist-title">Why this dossier should stay in the tab.</h2>
      </div>
      <div class="space-signal-grid">
        {cases.map((item, index) => (
          <a class="space-signal" href={`/formal/cases/${item.id}`} data-space-reveal style={`--delay: ${(index % 4) * 70}ms`}>
            <span>{item.metric}</span>
            <b>{item.title}</b>
            <small>{item.toneLine}</small>
          </a>
        ))}
      </div>
    </section>

    <section id="reels" class="space-section reel-section" aria-labelledby="reels-title">
      <div class="space-section-head" data-space-reveal>
        <p class="space-kicker">Embedded proof</p>
        <h2 id="reels-title">Direct work samples. No fake play layer.</h2>
        <p>Instagram reels stay vertical because they were made for a 1080x1920 world. The YouTube proof keeps its native player too.</p>
      </div>

      <div class="space-reel-grid">
        {reels.map((reel, index) => (
          <article class="space-reel-card" data-space-reveal style={`--delay: ${(index % 3) * 90}ms`}>
            <div class="space-reel-frame">
              <iframe
                src={reel.embedUrl}
                title={reel.title}
                loading="lazy"
                allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"
                allowfullscreen
              ></iframe>
            </div>
            <div class="space-reel-copy">
              <span>{reel.category} / {reel.platform}</span>
              <h3>{reel.title}</h3>
              <p>{reel.proof}</p>
              <a href={reel.openUrl} target="_blank" rel="noreferrer">Open original</a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="space-contact-band" aria-labelledby="contact-title" data-space-reveal>
      <div>
        <p class="space-kicker">Hiring channel</p>
        <h2 id="contact-title">Bring the operator into the room before the campaign gets polite.</h2>
      </div>
      <div class="space-contact-actions">
        <a href={mailHref}>{profile.email}</a>
        <a href={profile.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
        <a href={profile.instagram} target="_blank" rel="noreferrer">Instagram</a>
        <a href={profile.cvUrl} download>Download CV</a>
      </div>
    </section>
  </main>

  <script is:inline>
    const dossier = document.querySelector("[data-space-dossier]");
    const revealItems = document.querySelectorAll("[data-space-reveal]");

    if (dossier) {
      window.addEventListener("pointermove", (event) => {
        dossier.style.setProperty("--cursor-x", `${(event.clientX / window.innerWidth) * 100}%`);
        dossier.style.setProperty("--cursor-y", `${(event.clientY / window.innerHeight) * 100}%`);
      }, { passive: true });

      const finishBoot = () => dossier.classList.add("is-loaded");
      window.addEventListener("load", finishBoot, { once: true });
      window.setTimeout(finishBoot, 1300);
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) entry.target.classList.add("is-visible");
      });
    }, { threshold: 0.16 });

    revealItems.forEach((item) => observer.observe(item));

    document.querySelectorAll("[data-copy-pitch]").forEach((button) => {
      button.addEventListener("click", async () => {
        const original = button.textContent;
        try {
          await navigator.clipboard.writeText(button.dataset.copyPitch || "");
          button.textContent = "Pitch copied";
        } catch {
          button.textContent = "Copy failed";
        }
        window.setTimeout(() => {
          button.textContent = original;
        }, 1600);
      });
    });
  </script>
</BaseLayout>
