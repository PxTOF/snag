---
import BaseLayout from "../../layouts/BaseLayout.astro";
import profile from "../../data/profile.json";
import cases from "../../data/cases.json";
import reels from "../../data/reels.json";

const featuredCases = cases.slice(0, 4);
---

<BaseLayout
  title="Pushkar Vashisht - Formal Dossier"
  description="An editorial hiring dossier for Pushkar Vashisht: brand systems, creator growth, content machines and proof-led operating."
>
  <main class="dossier formal-dossier" data-dossier>
    <div class="redline-field" aria-hidden="true">
      <span>brand</span>
      <span>creator</span>
      <span>growth</span>
      <span>proof</span>
    </div>
    <div class="dossier-atmosphere" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </div>
    <div class="dossier-spine" aria-hidden="true">
      <span>Selected proof</span>
      <b>PV / 2050</b>
    </div>
    <header class="dossier-nav">
      <a class="brand-lockup" href="/">
        <img src={profile.profileImage} alt="Pushkar Vashisht" />
        <span>
          <b>{profile.name}</b>
          <small>Brand systems / creator growth</small>
        </span>
      </a>
      <nav aria-label="Formal dossier navigation">
        <a href="/xp">Fun XP</a>
        <a href="/contact">Contact</a>
        <a class="nav-cta" href={profile.cvUrl} download>Download CV</a>
      </nav>
    </header>

    <section class="dossier-hero">
      <div class="hero-copy">
        <div class="hero-meta">
          <span>Formal dossier</span>
          <span>Brand / growth / creator economy</span>
          <span>Available for sharp rooms</span>
        </div>
        <p class="eyebrow">Proof-led creative operator</p>
        <h1>
          <span class="hero-overline">I build the</span>
          <span class="hero-mega">MESSY</span>
          <span class="hero-mega hero-mega-red">MIDDLE</span>
          <em>brand / creators / growth</em>
        </h1>
        <p class="hero-claim">{profile.headline}</p>
        <p class="hero-lede">{profile.subheadline}</p>
        <div class="hero-actions">
          <a href="/contact">Hire / contact</a>
          <a href="#cases">Read the proof</a>
          <a href="/xp">Open Fun XP</a>
        </div>
        <div class="hero-proof-rail" aria-label="Fast proof">
          {profile.stats.slice(0, 3).map((stat) => (
            <span>
              <b>{stat.value}</b>
              <small>{stat.label}</small>
            </span>
          ))}
        </div>
        <div class="contact-chips" aria-label="Direct contact">
          <a href={`mailto:${profile.email}`}>{profile.email}</a>
          <a href={`tel:${profile.phone.replaceAll(" ", "")}`}>{profile.phone}</a>
          <a href={profile.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
        </div>
      </div>
      <aside class="signal-card">
        <span class="signal-stamp">proof<br />inside</span>
        <img src={profile.profileImage} alt="Pushkar smiling in a postage-stamp styled portrait" />
        <div>
          <p class="eyebrow">Current signal</p>
          <h2>Brand worlds, creator rooms, content machines.</h2>
          <p>{profile.pitch}</p>
        </div>
      </aside>
    </section>

    <section class="dossier-marquee" aria-label="Operating edge">
      <div>
        <span>creator supply</span>
        <span>paid activations</span>
        <span>brand rooms</span>
        <span>offline to online</span>
        <span>content machines</span>
        <span>taste with receipts</span>
      </div>
    </section>

    <section class="stat-strip" aria-label="Proof numbers">
      {profile.stats.map((stat) => (
        <div>
          <b>{stat.value}</b>
          <span>{stat.label}</span>
        </div>
      ))}
    </section>

    <section class="sticky-story" aria-label="Why hire Pushkar">
      <div class="sticky-intro">
        <p class="eyebrow">Why this works</p>
        <h2>Not a resume. A case for why the room changes when he enters it.</h2>
        <p>Scroll through the operating logic: culture first, proof always, taste visible in the execution.</p>
      </div>
      <div class="sticky-panels">
        <article class="sticky-panel" data-reveal>
          <span class="panel-number">01</span>
          <p class="eyebrow">What he is useful for</p>
          <h2>When the brand has a pulse but no operating system.</h2>
          <p>Pushkar is strongest where brand, creators, events, content and growth all touch each other. He can make the work feel culturally alive without losing the proof that makes HR and founders pay attention.</p>
        </article>
        <article class="sticky-panel panel-red" data-reveal>
          <span class="panel-number">02</span>
          <p class="eyebrow">Best fit</p>
          <h2>Internet-native brand and growth rooms.</h2>
          <ul>
            {profile.fit.map((item) => <li>{item}</li>)}
          </ul>
        </article>
        <article class="sticky-panel panel-cream" data-reveal>
          <span class="panel-number">03</span>
          <p class="eyebrow">Why it pulls</p>
          <h2>The numbers are there. The taste is not outsourced.</h2>
          <p>This dossier is built to show both sides: the operator who can move activations and rooms, and the creative brain that knows why generic marketing dies on arrival.</p>
        </article>
      </div>
    </section>

    <section id="cases" class="case-section" data-reveal>
      <div class="section-head">
        <p class="eyebrow">Case dossiers</p>
        <h2>Proof that has a point of view.</h2>
      </div>
      <div class="case-grid">
        {cases.map((item) => (
          <a class="case-card" href={`/formal/cases/${item.id}`}>
            <span>{item.year}</span>
            <small>{item.role}</small>
            <h3>{item.title}</h3>
            <p>{item.summary}</p>
            <b>{item.metric}</b>
          </a>
        ))}
      </div>
    </section>

    <section class="feature-case" data-reveal>
      <div>
        <p class="eyebrow">HR shortcut</p>
        <h2>If you only read four, read these.</h2>
      </div>
      <div class="feature-list">
        {featuredCases.map((item) => (
          <a href={`/formal/cases/${item.id}`}>
            <span>{item.metric}</span>
            <b>{item.title}</b>
            <small>{item.role}</small>
          </a>
        ))}
      </div>
    </section>

    <section class="reel-section" data-reveal>
      <div class="section-head">
        <p class="eyebrow">Screenings</p>
        <h2>Embedded work. No fake play layer.</h2>
      </div>
      <div class="reel-grid">
        {reels.map((reel) => (
          <article class="reel-tile">
            <div class="reel-frame">
              <iframe src={reel.embedUrl} title={reel.title} loading="lazy" allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share" allowfullscreen></iframe>
            </div>
            <div>
              <span>{reel.category} / {reel.platform}</span>
              <h3>{reel.title}</h3>
              <p>{reel.proof}</p>
              <a href={reel.openUrl} target="_blank" rel="noreferrer">Open original</a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="closing-cta" data-reveal>
      <p class="eyebrow">Close the loop</p>
      <h2>Useful in the room where the idea has to become output.</h2>
      <div>
        <a href={`mailto:${profile.email}`}>Email Pushkar</a>
        <a href={profile.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
        <a href={profile.cvUrl} download>Download CV</a>
      </div>
    </section>
  </main>

  <script>
    const dossier = document.querySelector("[data-dossier]");

    if (dossier) {
      const setPointer = (event) => {
        const rect = dossier.getBoundingClientRect();
        dossier.style.setProperty("--spot-x", `${event.clientX - rect.left}px`);
        dossier.style.setProperty("--spot-y", `${event.clientY - rect.top}px`);
      };

      window.addEventListener("pointermove", setPointer, { passive: true });

      const revealItems = document.querySelectorAll("[data-reveal]");
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) entry.target.classList.add("is-visible");
        });
      }, { threshold: 0.16 });

      revealItems.forEach((item) => observer.observe(item));
    }
  </script>
</BaseLayout>
